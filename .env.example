# Model path (relative to project root or absolute)
AUDIOSUB_MODEL=models/vosk-model-small-ru-0.22
# Language code
AUDIOSUB_LANG=ru-RU
# PulseAudio monitor source device
AUDIOSUB_DEVICE=default
# Output subtitle file
AUDIOSUB_OUTPUT=subtitles.srt
# Subtitle format: srt or vtt
AUDIOSUB_FORMAT=srt
# Log level: trace, debug, info, warn, error
RUST_LOG=audiosub=info
