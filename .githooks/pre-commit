#!/usr/bin/env bash
set -e

REPORT_DIR="reports"
CHANGED_FILES=$(git diff --cached --name-only)
# Skip hook if only report files changed (prevents recursive reports)
if [ -z "$CHANGED_FILES" ] || ! echo "$CHANGED_FILES" | grep -qv "^$REPORT_DIR/"; then
    echo "[githook] Only report files changed, skipping template creation"
    exit 0
fi

mkdir -p "$REPORT_DIR"

TIMESTAMP=$(date -u '+%Y-%m-%d %H:%M:%S UTC')
FILENAME="$(date -u '+%Y-%m-%d_%H-%M-%S').md"
FILEPATH="$REPORT_DIR/$FILENAME"

CURRENT_BRANCH=$(git branch --show-current)

# Convert newlines to spaces for the template header
CHANGED_FILES_STR=$(echo "$CHANGED_FILES" | tr '\n' ' ')

cat > "$FILEPATH" <<EOF
# Commit Report

**Date:** $TIMESTAMP
**Branch:** $CURRENT_BRANCH
**Files changed:** $CHANGED_FILES_STR

## What was added

-

## What was changed

-

## Problems encountered

-

## How they were solved

-

---

EOF

echo "[githook] Report created: $FILEPATH"
echo "[githook] Please review and edit: $FILEPATH"
